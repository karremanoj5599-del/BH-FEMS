# FEMS Environment Configuration
# Copy this file to .env and update values for your environment

# Database (SQLite for local dev, PostgreSQL for production)
# DATABASE_URL=postgresql://fems_user:fems_password@localhost:5432/fems_db
DATABASE_URL=sqlite:///./fems_dev.db

# JWT
JWT_SECRET_KEY=fems-super-secret-key-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:5174","http://localhost:5175","http://localhost:5180"]

# Debug
DEBUG=True
